61. Rotate List

Given the head of a linked list, rotate the list to the right by k places.
Input: head = [1,2,3,4,5], k = 2
Output: [4,5,1,2,3]

Input: head = [0,1,2], k = 4
Output: [2,0,1]

class Solution {
    public ListNode rotateRight(ListNode head, int k) {
        if(head==null || head.next==null){
            return head;
        }
        //calculate length
        int length=0;
        ListNode curr=head;
        while(curr!=null){
            curr=curr.next;
            length++;
        }
        k=k%length;
        if(k==0){
            return head;
        }
        ListNode s=head;
        ListNode f=head;
        for(int i=0;i<k;i++){
            f=f.next;
        }
        while(f.next!=null){
            s=s.next;
            f=f.next;
        }
        ListNode NewHead=s.next;
        s.next=null;
        f.next=head;
        return NewHead;
    }
}
